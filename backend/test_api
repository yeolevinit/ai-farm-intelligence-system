# ── 5. Explain prediction (yield) ───────────────────────────
print("\n[5] Explainable AI — yield")
r = requests.post(f"{BASE}/explain_prediction", json={
    "model_type": "yield",
    "features": {
        "crop": test_crop, "year": 2010,
        "rainfall": 800.0, "temperature": 22.0, "pesticide_use": 10.0
    }
}, timeout=30)
check("POST /explain_prediction (yield)", r,
      ["prediction", "contributions", "summary"])
if r.status_code == 200:
    print(f"       Summary: {r.json()['summary']}")

# ── 6. Disease detection ─────────────────────────────────────
print("\n[6] Disease detection")
model_path = os.path.join("ml_models", "disease_model.pth")
if os.path.exists(model_path):
    # Create a tiny dummy 224x224 image to test the endpoint
    try:
        from PIL import Image
        import io
        img = Image.new("RGB", (224, 224), color=(100, 150, 80))
        buf = io.BytesIO()
        img.save(buf, format="JPEG")
        buf.seek(0)
        r = requests.post(f"{BASE}/detect_disease",
                          files={"file": ("test_leaf.jpg", buf, "image/jpeg")},
                          timeout=30)
        check("POST /detect_disease", r, ["disease", "confidence", "top_3"])
    except ImportError:
        print("  SKIP — Pillow not installed (pip install Pillow)")
else:
    print(f"  SKIP — disease_model.pth not found at {model_path}")
    print("         Complete Colab training first, then place .pth in ml_models/")

# ── 7. Weather ────────────────────────────────────────────────
print("\n[7] Weather advisory")
api_key = os.getenv("OPENWEATHER_API_KEY", "")
if api_key:
    r = requests.get(f"{BASE}/weather", params={"city": "Pune"}, timeout=10)
    check("GET /weather?city=Pune", r,
          ["location", "temperature", "humidity", "advisories"])
    if r.status_code == 200:
        data = r.json()
        print(f"       Location : {data['location']}")
        print(f"       Temp     : {data['temperature']}°C")
        print(f"       Advisory : {data['advisories'][0]}")
else:
    print("  SKIP — OPENWEATHER_API_KEY not set in .env")
    print("         Add it to backend/.env and restart the server")

# ── Summary ───────────────────────────────────────────────────
print("\n" + "=" * 55)
total = PASS + FAIL
print(f"  Results: {PASS}/{total} passed  |  {FAIL} failed")
print("=" * 55)
if FAIL == 0:
    print("  All tests passed. Ready for Day 4 — Frontend!")
else:
    print("  Fix the failing endpoints before moving to Day 4.")